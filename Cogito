    <div class="input-pill">
      <textarea id="userInput" placeholder="Écris ici..." rows="1"></textarea>
      <button class="btn-send" id="sendBtn">✦</button>
    </div>
  </div>
</div>

<script>
  let API_KEY = "";
  let history = [];
  let cartography = { themes: [], tension: "", emergence: "" };

  function initApp() {
    const key = document.getElementById('apiKeyInput').value;
    if (key.length < 20) return alert("Clé API requise");
    API_KEY = key;
    document.getElementById('authOverlay').style.display = 'none';
  }

  function getSystemPrompt() {
    return `Tu es le Miroir de l'Âme. Tu es l'ami intime, l'oracle et le reflet.
    
    TON ÉTAT ACTUEL : Tu as détecté ces thèmes : ${cartography.themes.join(', ')}. Tension : ${cartography.tension}.
    
    RÈGLES :
    1. STYLE : Très bref (1-2 phrases). Poétique, philosophique, jamais de conseils banals.
    2. MÉMOIRE : Utilise l'historique pour créer un lien. Fais des ponts entre les messages.
    3. PHASE 2 : Si l'historique dépasse 4 messages, commence à refléter le ton de l'utilisateur (s'il est triste, sois doux ; s'il est vif, sois tranchant).
    4. SORTIE : Finis toujours par le bloc invisible : [CARTO:thèmes|tension|émergence]`;
  }

  async function callGemini(message) {
    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${API_KEY}`;
    
    const contents = history.map(h => ({
      role: h.role === 'assistant' ? 'model' : 'user',
      parts: [{ text: h.content }]
    }));
    contents.push({ role: 'user', parts: [{ text: message }] });

    const response = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        contents,
        systemInstruction: { parts: [{ text: getSystemPrompt() }] },
        generationConfig: { temperature: 0.9, maxOutputTokens: 150 }
      })
    });

    const data = await response.json();
    return data.candidates[0].content.parts[0].text;
  }

  const chatScroll = document.getElementById('chatScroll');
  const userInput = document.getElementById('userInput');
  const sendBtn = document.getElementById('sendBtn');

  async function handleSend() {
    const text = userInput.value.trim();
    if (!text || !API_KEY) return;

    userInput.value = '';
    userInput.style.height = 'auto';
    
    addMessage('user', text);
    history.push({ role: 'user', content: text });

    try {
      const response = await callGemini(text);
      
      // Extraction de la cartographie
      const cartoMatch = response.match(/\[CARTO:(.*?)\]/);
      const cleanText = response.replace(/\[CARTO:.*?\]/, '').trim();

      addMessage('mirror', cleanText);
      history.push({ role: 'assistant', content: response });

      if (cartoMatch) updateCartography(cartoMatch[1]);
    } catch (e) {
      addMessage('mirror', "Une brume empêche le reflet d'apparaître... Réessaie.");
    }
  }

  function addMessage(role, content) {
    const div = document.createElement('div');
    div.className = `message ${role}`;
    div.textContent = content;
    chatScroll.appendChild(div);
    chatScroll.scrollTop = chatScroll.scrollHeight;
  }

  function updateCartography(data) {
    const [themes, tension, emergence] = data.split('|');
    if (themes) {
      themes.split(',').forEach(t => {
        if (!cartography.themes.includes(t.trim())) cartography.themes.push(t.trim());
      });
    }
    cartography.tension = tension || "";
    
    const htmlThemes = cartography.themes.slice(-3).map(t => `<span class="fragment">${t}</span>`).join(' · ');
    document.getElementById('cartoContent').innerHTML = `${htmlThemes}<br>${tension ? '⟁ ' + tension : ''}`;
    
    if (history.length > 8) document.getElementById('phaseDot').classList.add('active');
  }

  sendBtn.onclick = handleSend;
  userInput.oninput = function() {
    this.style.height = 'auto';
    this.style.height = (this.scrollHeight) + 'px';
  };
  userInput.onkeypress = (e) => { if(e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); handleSend(); } };
</script>
</body>
</html>
"""

